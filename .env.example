# JARVIS Configuration
# Copy this file to .env and fill in your values

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Voice Settings ────────────────────────────────────────────────────────────
VOICE_RATE=175          # Speech speed (words per minute)
VOICE_VOLUME=1.0        # Volume 0.0 - 1.0
VOICE_ID=0              # 0=default, 1=second voice if available
WAKE_WORD=jarvis        # Word that activates listening

# ── Email (for messaging feature) ────────────────────────────────────────────
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here   # Gmail App Password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Paths ─────────────────────────────────────────────────────────────────────
DOWNLOADS_FOLDER=~/Downloads
DOCUMENTS_FOLDER=~/Documents
DESKTOP_FOLDER=~/Desktop

# ── Features ─────────────────────────────────────────────────────────────────
ENABLE_SCREEN_WATCH=true     # JARVIS watches your screen
ENABLE_WAKE_WORD=true        # Wake word activation
SCREEN_WATCH_INTERVAL=10     # Seconds between screen checks
